# Copy this file to `.env` and paste your real key in.
#
#   cp .env.example .env
#
# Get a key from https://console.anthropic.com/settings/keys
# NEVER commit your real .env file. It is already in .gitignore.

ANTHROPIC_API_KEY=sk-ant-your-key-here

# OPTIONAL — only for the embeddings example (examples/12_embeddings.py).
# Anthropic has no first-party embeddings endpoint and recommends Voyage AI,
# a separate provider with its own key. Get one at https://www.voyageai.com/
VOYAGE_API_KEY=pa-your-voyage-key-here

